{
  "expo": {
    "name": "BEN Ecosystem IA",
    "slug": "ben-ecosystem-ia",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "benecosystem",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f2044"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.adv.mauromoncao.benecosystem",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Permite capturar fotos de documentos para análise jurídica.",
        "NSMicrophoneUsageDescription": "Permite gravação de áudio para transcrição.",
        "NSPhotoLibraryUsageDescription": "Permite selecionar imagens de documentos.",
        "NSDocumentsFolderUsageDescription": "Permite acessar e exportar documentos jurídicos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#0f2044",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "br.adv.mauromoncao.benecosystem",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ben-ecosystem-ia"
      }
    },
    "owner": "mauromoncao"
  }
}
